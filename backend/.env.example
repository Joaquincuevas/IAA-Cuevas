# Groq API key (obligatoria para Taula y análisis IA batch)
# Obtener en https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Llamadas Groq en paralelo durante batch (free tier: 2 recomendado)
GROQ_MAX_WORKERS=2

# Rutas locales con docker-compose (volumen ./data:/data)
DATA_PATH=/data/RA_UandesFunctional.xlsx
APP_DB=/data/app.db

# En Render Free (Docker) no hace falta definir DATA_PATH ni APP_DB:
# el Dockerfile usa /app/data/... (filesystem efímero; app.db se pierde en redeploys)

# Clave secreta para firmar JWT — CAMBIAR en producción, nunca dejar el valor por defecto
SECRET_KEY=trace-analytics-dev-secret-change-me

# CORS: origins permitidos (separados por coma)
# En producción: URL del frontend en Vercel
ALLOWED_ORIGINS=http://localhost:3000
