# Groq API key (obligatoria para el módulo de análisis IA y Taula)
# Obtener en https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Llamadas Groq en paralelo durante batch (free tier: 2 recomendado)
GROQ_MAX_WORKERS=2

# Google Gemini (solo para la versión Streamlit legacy, opcional)
GEMINI_API_KEY=

# Ruta al Excel principal (por defecto relativa al Dockerfile)
DATA_PATH=/data/RA_UandesFunctional.xlsx

# Ruta a la BD SQLite (usuarios, historial, propuestas IA, votos)
APP_DB=/data/app.db

# Clave secreta para firmar JWT (cambiar en producción)
SECRET_KEY=trace-analytics-dev-secret-change-me

# CORS: origins permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000
